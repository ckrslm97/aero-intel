# Copy to .env and adjust. Every value below is optional except DATABASE_URL --
# unset optional values make the app fall back to an in-process/dry-run implementation.

ENVIRONMENT=development
DEBUG=true
SECRET_KEY=change-me-to-a-long-random-string
CORS_ORIGINS=["http://localhost:3000"]

# --- Database (required) ---
DATABASE_URL=postgresql+asyncpg://localhost:5432/aerointel

# --- Cache (optional; falls back to in-process memory cache) ---
# REDIS_URL=redis://localhost:6379/0

# --- Search (optional; falls back to Postgres full-text search) ---
# ELASTICSEARCH_URL=http://localhost:9200

# --- LLM provider (optional; falls back to the built-in heuristic pipeline, no key needed) ---
# The LLM is what makes Turkish translation and good categorisation possible;
# without one the app still runs, and untranslated articles say so in the UI.
#
# Groq (what the deployed GitHub Actions jobs use -- free key at console.groq.com):
# LLM_PROVIDER=openai_compat
# LLM_MODEL=llama-3.3-70b-versatile
# LLM_MODEL_FAST=llama-3.1-8b-instant
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_API_KEY=gsk_...
#
# Mind the free-tier budget when changing models. Per day, per model:
#   llama-3.3-70b-versatile -- 1,000 requests / 100k tokens (best Turkish)
#   llama-3.1-8b-instant    -- 14,400 requests / 500k tokens (weaker Turkish)
# Enrichment spends the LLM only where it earns its keep, and splits the two:
# quality-critical translation -> LLM_MODEL (70b), token-heavy categorisation ->
# LLM_MODEL_FAST (8b, 5x the token budget). That keeps a live run within budget
# for ~140 articles/day. See app/llm/factory.py. LLM_FULL_PIPELINE=true sends
# every task to the LLM -- only worth it on a paid tier.
# LLM_FULL_PIPELINE=false
#
# Per-run enrichment cap so one scheduled job can't drain the daily budget
# (jobs-news.yml runs 12x/day: 12 x 12 = ~140 articles/day). Default 12.
# LLM_ENRICH_BATCH_SIZE=12
#
# Other OpenAI-wire-compatible options:
# LLM_MODEL=gpt-4o-mini / LLM_BASE_URL=https://api.openai.com/v1 / LLM_API_KEY=sk-...
# Local Ollama: LLM_PROVIDER=ollama, LLM_MODEL=llama3.1, LLM_BASE_URL=http://localhost:11434
#   (small local models translate Turkish poorly -- qwen2.5:3b produced nonsense in testing)

# --- Email (optional; unset = writes HTML to ../outbox instead of sending) ---
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=you@gmail.com
# SMTP_PASSWORD=app-password
# EMAIL_FROM=newsroom@yourdomain.com

# --- Storage ---
STORAGE_BACKEND=local
STORAGE_LOCAL_DIR=../storage
# S3_BUCKET=
# S3_ENDPOINT_URL=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=

# --- Scheduler ---
SCHEDULER_ENABLED=true
DAILY_EDITION_HOUR_UTC=4
DAILY_NEWSLETTER_HOUR_UTC=5
