# Playwright
HEADLESS=true
PAGE_TIMEOUT_MS=30000
NAV_TIMEOUT_MS=45000
USER_AGENT=

# İnsan davranışı taklidi (saniye)
HUMAN_DELAY_MIN=0.4
HUMAN_DELAY_MAX=1.8

# Retry
MAX_RETRIES=3
RETRY_BACKOFF=2.0

# Eşzamanlılık
# MAX_WORKERS: paralel işlenecek taşıyıcı grubu sayısı (her grup kendi tarayıcısı)
MAX_WORKERS=3
# PAGES_PER_BROWSER: aynı taşıyıcı+tarih için tek tarayıcıda eşzamanlı sekme sayısı
PAGES_PER_BROWSER=4

# Demo / çevrimdışı mod (true ise canlı istek atılmaz, sahte veri üretilir)
DEMO_MODE=false

# OTA yedeği: havayolu sitesinden veri alınamazsa OTA'lardan dene
USE_OTA_FALLBACK=true
OTA_SOURCES=google,kayak

# Resmi API kaynakları (canlı modda ÖNCE denenir; token varsa). Fare-family için
# en güvenilir yol. Token yoksa ilgili sağlayıcı sessizce atlanır.
USE_API_SOURCES=true
API_SOURCES=duffel,amadeus
API_TIMEOUT_S=30

# Duffel — https://duffel.com (token: duffel_test_... / duffel_live_...)
DUFFEL_ACCESS_TOKEN=
DUFFEL_API_VERSION=v2

# Amadeus Self-Service — https://developers.amadeus.com (env: test | production)
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
AMADEUS_ENV=test

# Çıktı
OUTPUT_DIR=output
EXPORT_EXCEL=true
EXPORT_CSV=true
EXPORT_SQLITE=true
EXPORT_JSON=true

# Resume / dedup
RESUME=true
SKIP_EXISTING=true

# Uçuş tarihi (boşsa bugünden DAYS_AHEAD gün sonrası)
TRAVEL_DATE=
DAYS_AHEAD=30

# Logging
LOG_DIR=logs
