# Variables consumed by docker-compose.yml (docker-compose reads .env in this
# directory automatically). Copy to .env before `docker compose up`.
# For local (non-Docker) dev, see backend/.env.example and frontend/.env.local.example instead.

POSTGRES_PASSWORD=change-me
SECRET_KEY=change-me-to-a-long-random-string

# Public URL the browser will use to reach the API through nginx.
NEXT_PUBLIC_API_URL=http://localhost/api/v1

# Optional: LLM provider (unset = built-in heuristic pipeline, no key needed)
LLM_PROVIDER=heuristic
LLM_BASE_URL=
LLM_API_KEY=

# Optional: SMTP (unset = newsletters write to the outbox_data volume instead of sending)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=newsroom@yourdomain.com
